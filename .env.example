# Hyperliquid Kodiak Keeper Configuration

# Master wallet private key (hex, without 0x prefix)
HL_PRIVATE_KEY=

# Agent wallet private key (for delegation — optional, uses master if not set)
HL_AGENT_PRIVATE_KEY=

# Vault address (set after creating vault)
HL_VAULT_ADDRESS=

# Network: mainnet or testnet
HL_NETWORK=testnet
